G[1] = {sn:"Féca",ln:"Le rempart éternel",ep:1,d:"Gardiens éternels des secrets anciens, les Fécas maîtrisent l\'art défensif depuis des millénaires. Leurs boucliers mystiques repoussent les attaques les plus féroces tandis que leurs glyphes sacrés protègent leurs alliés. Face à la mort, ils restent impassibles, car ils savent que leur devoir est de préserver la vie de ceux qui les entourent.",sd:"Gardien éternel, bouclier vivant. Sa magie protège, ses sorts repoussent. Rempart inébranlable.",s:[3,17,6,4,2,1,9,18,20,14,19,5,16,8,12,11,10,7,15,13,1901],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[100,2],[200,3],[300,4],[400,5],[500,5]],b11:[[0,1]],b12:[[0,3]],b13:[[100,2],[200,3],[300,4],[400,5],[500,5]],b14:[[100,2],[200,3],[300,4],[400,5],[500,5]],b15:[[100,2],[200,3],[300,4],[400,5],[500,5]]};
G[2] = {sn:"Osamodas",ln:"L\'âme sauvage",ep:1,d:"Héritiers d\'un pacte ancestral avec les créatures du monde, les Osamodas communient avec les bêtes sauvages. Dragons cracheurs de feu, loups des steppes ou créatures des abysses, tous répondent à leur appel. Leur fouet ne dresse pas seulement les monstres, il forge des liens éternels entre l\'homme et la bête.",sd:"Dompteur de créatures, invoque dragons et monstres. Les bêtes lui obéissent aveuglément.",s:[23,34,21,26,22,35,28,37,30,27,24,33,25,38,36,32,29,39,40,31,1902],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[100,2],[200,3],[300,4],[400,5],[500,5]],b11:[[0,1]],b12:[[0,3]],b13:[[100,2],[200,3],[300,4],[400,5],[500,5]],b14:[[100,2],[200,3],[300,4],[400,5],[500,5]],b15:[[100,2],[200,3],[300,4],[400,5],[500,5]]};
G[3] = {sn:"Enutrof",ln:"Le chercheur d\'or",ep:1,d:"Chercheurs obsessionnels des trésors perdus, les Enutrofs voient en chaque aventure une opportunité d\'enrichissement. Leurs doigts agiles désamorcent les pièges les plus mortels, leurs yeux brillent à la vue de l\'or. Mais attention, car derrière leur avarice se cache une ruse millénaire et des pouvoirs terreux redoutables.",sd:"Chercheur d\'or avare. Ses sorts terreux protègent ses kamas précieux. Riche et malin.",s:[51,41,43,49,42,47,48,45,53,46,52,44,50,54,55,56,58,59,57,60,1903],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[100,2],[200,3],[300,4],[400,5],[500,5]],b11:[[0,1]],b12:[[0,3]],b13:[[100,2],[200,3],[300,4],[400,5],[500,5]],b14:[[100,2],[200,3],[300,4],[400,5],[500,5]],b15:[[100,2],[200,3],[300,4],[400,5],[500,5]]};
G[4] = {sn:"Sram",ln:"L\'assassin silencieux",ep:1,d:"Nés des ombres et nourris par le silence, les Srams sont les maîtres de l\'art de tuer. Leurs lames empoisonnées murmurent la mort, leurs pièges sournois fauchent les imprudents. Invisibles comme la nuit, mortels comme le venin, ils frappent là où on ne les attend jamais avant de disparaître dans les ténèbres.",sd:"Assassin des ombres, frappe dans le dos. Poison et discrétion, mort silencieuse assurée.",s:[65,72,61,66,68,63,74,64,79,78,71,62,69,77,73,67,70,75,76,80,1904],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[100,2],[200,3],[300,4],[400,5],[500,5]],b11:[[0,1]],b12:[[0,3]],b13:[[100,2],[200,3],[300,4],[400,5],[500,5]],b14:[[100,2],[200,3],[300,4],[400,5],[500,5]],b15:[[100,2],[200,3],[300,4],[400,5],[500,5]]};
G[5] = {sn:"Xélor",ln:"Le maître du temps",ep:1,d:"Gardiens du temps et maîtres des horloges cosmiques, les Xélors manipulent les fils temporels avec une précision chirurgicale. Ils ralentissent leurs ennemis, accélèrent leurs alliés et se téléportent à travers l\'espace-temps. Leur sablier ne mesure pas les heures, il les commande.",sd:"Maître du temps, manipule les heures. Téléportation et ralentissement, contrôle temporel absolu.",s:[81,83,82,84,100,92,88,93,85,96,98,86,89,90,87,94,99,95,91,97,1905],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[100,2],[200,3],[300,4],[400,5],[500,5]],b11:[[0,1]],b12:[[0,3]],b13:[[100,2],[200,3],[300,4],[400,5],[500,5]],b14:[[100,2],[200,3],[300,4],[400,5],[500,5]],b15:[[100,2],[200,3],[300,4],[400,5],[500,5]]};
G[6] = {sn:"Ecaflip",ln:"La chance aveugle",ep:1,d:"Joueurs compulsifs guidés par le hasard pur, les Ecaflips font de chaque combat un pari mortel. Leurs sorts imprévisibles peuvent aussi bien sauver que damner. Pile ou face, chance ou malédiction, ils embrassent le chaos avec un sourire carnassier. Car au final, la chance sourit toujours aux audacieux.",sd:"Joueur fou, tout au hasard. Chance ou malédiction, le destin décide pour lui.",s:[102,103,105,109,113,111,104,119,101,107,116,106,117,108,115,118,110,112,114,120,1906],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[100,2],[200,3],[300,4],[400,5],[500,5]],b11:[[0,1]],b12:[[0,3]],b13:[[100,2],[200,3],[300,4],[400,5],[500,5]],b14:[[100,2],[200,3],[300,4],[400,5],[500,5]],b15:[[100,2],[200,3],[300,4],[400,5],[500,5]]};
G[7] = {sn:"Eniripsa",ln:"Le souffle de vie",ep:1,d:"Guérisseurs divins touchés par la grâce et la malédiction, les Eniripsas portent en eux le pouvoir de vie et de mort. Leurs mots sacrés ressuscitent les mourants, mais leurs paroles maudites foudroient les vivants. Entre lumière et ténèbres, ils maintiennent l\'équilibre fragile de l\'existence.",sd:"Soigneur divin, vie et mort entre ses mains. Guérit les alliés, damne les ennemis.",s:[125,128,121,124,122,126,127,123,130,131,132,133,134,135,129,136,137,138,139,140,1907],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[100,2],[200,3],[300,4],[400,5],[500,5]],b11:[[0,1]],b12:[[0,3]],b13:[[100,2],[200,3],[300,4],[400,5],[500,5]],b14:[[100,2],[200,3],[300,4],[400,5],[500,5]],b15:[[100,2],[200,3],[300,4],[400,5],[500,5]]};
G[8] = {sn:"Iop",ln:"Le sang du guerrier",ep:1,d:"Guerriers nés pour la bataille, les Iops incarnent la fureur pure et la bravoure aveugle. Leur cœur ne connaît ni la peur ni le doute, seulement la soif de combat. Épée à la main, ils chargent vers la gloire ou la mort, car pour eux, mourir au combat est le plus bel honneur qui soit.",sd:"Guerrier fou, il charge sans réfléchir. Sa lame tranche, son courage inspire. Gloire ou mort !",s:[142,143,141,144,145,146,147,148,154,150,151,155,152,153,149,156,157,158,160,159,1908],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[100,2],[200,3],[300,4],[400,5],[500,5]],b11:[[0,1]],b12:[[0,3]],b13:[[100,2],[200,3],[300,4],[400,5],[500,5]],b14:[[100,2],[200,3],[300,4],[400,5],[500,5]],b15:[[100,2],[200,3],[300,4],[400,5],[500,5]]};
G[9] = {sn:"Crâ",ln:"La flèche mortelle",ep:1,d:"Archers d\'élite dont la précision défie les lois de la nature, les Crâs ne ratent jamais leur cible. Leurs flèches percent les armures les plus solides, leurs yeux voient à travers les illusions. Distance et patience sont leurs vertus, car un tir bien placé vaut mille coups d\'épée maladroits.",sd:"Archer précis, ses flèches ne ratent jamais. Distance et patience, tir mortel garanti.",s:[169,164,161,163,165,172,167,168,162,170,171,166,173,174,176,175,178,177,179,180,1909],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[100,2],[200,3],[300,4],[400,5],[500,5]],b11:[[0,1]],b12:[[0,3]],b13:[[100,2],[200,3],[300,4],[400,5],[500,5]],b14:[[100,2],[200,3],[300,4],[400,5],[500,5]],b15:[[100,2],[200,3],[300,4],[400,5],[500,5]]};
G[10] = {sn:"Sadida",ln:"L\'esprit de la forêt",ep:1,d:"Sorciers végétaux liés aux forces primitives de la nature, les Sadidas commandent aux plantes et aux esprits. Leurs poupées vaudou dansent une macabre sarabande tandis que leurs ronces empoisonnées étranglent leurs ennemis. Magie verte et sorcellerie noire s\'entremêlent dans leurs rituels interdits.",sd:"Maître végétal, contrôle nature et poupées vaudou. Magie verte primitive et sauvage.",s:[193,183,200,198,195,182,192,197,189,181,199,191,186,196,190,194,185,184,188,187,1910],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[100,2],[200,3],[300,4],[400,5],[500,5]],b11:[[0,1]],b12:[[0,3]],b13:[[100,2],[200,3],[300,4],[400,5],[500,5]],b14:[[100,2],[200,3],[300,4],[400,5],[500,5]],b15:[[100,2],[200,3],[300,4],[400,5],[500,5]]};
G[11] = {sn:"Sacrieur",ln:"La souffrance éternelle",ep:1,d:"Berzerkers masochistes qui puisent leur force dans la douleur, les Sacrieurs transforment chaque blessure en rage meurtrière. Plus ils souffrent, plus ils deviennent dangereux. Leur sang versé nourrit leur fureur, leurs cicatrices racontent leurs victoires. La souffrance est leur religion, la guerre leur prière.",sd:"Berzerker masochiste, plus il souffre plus il frappe. Douleur source de puissance brute.",s:[431,432,434,444,449,436,437,439,433,443,440,442,441,445,438,446,447,448,435,450,1911],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[100,2],[200,3],[300,4],[400,5],[500,5]],b11:[[0,1,2]],b12:[[0,3]],b13:[[100,2],[200,3],[300,4],[400,5],[500,5]],b14:[[100,2],[200,3],[300,4],[400,5],[500,5]]};
G[12] = {sn:"Pandawa",ln:"La force de l\'alcool",ep:18,d:"Guerriers ivres dont l\'alcool décuple la force et embrume la raison, les Pandawas combattent dans un état d\'ébriété contrôlée. Ils portent leurs alliés sur leurs épaules et projettent leurs ennemis dans les airs. Leur chopine n\'est jamais vide, car l\'alcool coule dans leurs veines comme un élixir de puissance.",sd:"Guerrier ivre, alcool décuple sa force. Porte alliés, projette ennemis dans les airs.",s:[686,692,687,689,690,691,688,693,694,695,696,697,698,699,700,701,702,703,704,705,1912],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[100,2],[200,3],[300,4],[400,5],[500,5]],b11:[[0,1]],b12:[[0,3]],b13:[[100,2],[200,3],[300,4],[400,5],[500,5]],b14:[[100,2],[200,3],[300,4],[400,5],[500,5]],b15:[[100,2],[200,3],[300,4],[400,5],[500,5]]};
